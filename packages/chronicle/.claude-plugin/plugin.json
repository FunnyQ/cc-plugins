{
  "name": "chronicle",
  "version": "0.8.2",
  "description": "Write and guard your project's history — craft commits (auto simple/atomic) and author reviewer-legible PRs/MRs enriched by the cockpit decision trail.",
  "author": { "name": "Q" },
  "license": "MIT",
  "keywords": [
    "chronicle",
    "git",
    "commit",
    "pull-request",
    "merge-request",
    "github",
    "gitlab",
    "history"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-branch.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
