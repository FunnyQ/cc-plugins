{
  "name": "monitor",
  "version": "3.8.0",
  "description": "Monitor your Claude Code and Codex sessions — a usage dashboard (sessions, tokens, cost, model mix, project activity) plus a per-project cockpit (goal capture, decision log, live session view).",
  "author": {
    "name": "Q"
  },
  "license": "MIT",
  "keywords": [
    "dashboard",
    "stats",
    "usage",
    "cockpit",
    "goal",
    "decision-log",
    "live-session",
    "claude-code",
    "codex"
  ],
  "mcpServers": {
    "cockpit-channel": {
      "type": "stdio",
      "command": "bun",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/skills/cockpit/scripts/cockpit-channel.ts"
      ]
    }
  },
  "channels": [
    {
      "server": "cockpit-channel"
    }
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/skills/install/scripts/setup.ts\" --session-check",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
