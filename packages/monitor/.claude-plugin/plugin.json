{
  "name": "monitor",
  "version": "3.19.2",
  "description": "Monitor your Claude Code, Codex, and OpenCode sessions — a usage dashboard plus a per-project cockpit with a decision trail, live session view, needs-your-call bridge, and thoughtful auto-logging.",
  "author": {
    "name": "Q"
  },
  "license": "MIT",
  "keywords": [
    "dashboard",
    "stats",
    "usage",
    "cockpit",
    "decision-trail",
    "live-session",
    "claude-code",
    "codex",
    "opencode"
  ],
  "mcpServers": {
    "cockpit-channel": {
      "type": "stdio",
      "command": "bun",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/skills/cockpit/scripts/cockpit-channel.ts"
      ]
    }
  },
  "channels": [
    {
      "server": "cockpit-channel"
    }
  ],
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/skills/install/scripts/setup.ts\" --session-check",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/skills/cockpit/scripts/decision-log-start.ts\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${CLAUDE_PLUGIN_ROOT}/skills/cockpit/scripts/scribe-nudge.ts\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
