{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${PLUGIN_ROOT}/skills/install/scripts/setup.ts\" --session-check",
            "timeout": 20
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${PLUGIN_ROOT}/skills/cockpit/scripts/decision-log-start.ts\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun \"${PLUGIN_ROOT}/skills/cockpit/scripts/scribe-nudge.ts\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
